#!/bin/bash
# Cognitive Monitor 环境变量配置
# 复制此文件为 .env 并填入实际值

# Upstash Redis 配置（必须）
export UPSTASH_REDIS_REST_URL="https://singular-snake-71209.upstash.io"
export UPSTASH_REDIS_REST_TOKEN="your-token-here"

# 工作空间路径
export COGNITIVE_WORKSPACE="/root/.openclaw/agents/main/sessions"
export COGNITIVE_DB_PATH="/var/lib/cognitive_monitor/history.db"

# API 服务配置
export COGNITIVE_API_PORT="8080"

# 日志配置
export COGNITIVE_LOG_LEVEL="INFO"
export COGNITIVE_LOG_FILE="/var/log/cognitive_monitor.log"

# 监控间隔（秒）
export COGNITIVE_CHECK_INTERVAL="30"

# 缓存TTL（秒）
export COGNITIVE_CACHE_TTL="60"

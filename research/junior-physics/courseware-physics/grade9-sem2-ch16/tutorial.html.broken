    <p style="margin-top: 8px; font-size: 0.75rem;">
      从 10<sup>-10</sup> m 的原子核到 10<sup>26</sup> m 的宇宙边缘 —— 人类认知的边界，就是探索的起点。
    </p>
  </footer>

</div>

<script>
function checkAnswer(unit, qnum, choice, correct) {
  var fb = document.getElementById('fb' + unit + '-' + qnum);
  if (choice === correct) {
    fb.textContent = '✓ 正确！';
    fb.style.color = '#00ff88';
  } else {
    fb.textContent = '✗ 不对，再想想？';
    fb.style.color = '#ff5555';
  }
  fb.style.display = 'block';
}
function toggleAnswer(id) {
  var el = document.getElementById(id);
  if (el.style.display === 'none') {
    el.style.display = 'block';
  } else {
    el.style.display = 'none';
  }
}
</script>
